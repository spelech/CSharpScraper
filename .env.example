# Environment configuration template for Playwright C# Scraper

# Timezone setting for the container
TZ=America/Chicago

# --- LLM Provider Settings ---
# URL for the OpenAI-compatible chat completion API endpoint.
# Fallback default: http://litellm:4000/v1 (or you can point directly to OpenRouter, OpenAI, Anthropic via local proxy, etc.)
# Examples: 
# - OpenAI: https://api.openai.com/v1
# - OpenRouter: https://openrouter.ai/api/v1
# - Local Ollama: http://host.docker.internal:11434/v1
DEFAULT_LLM_BASE_URL=http://litellm:4000/v1
DEFAULT_LLM_API_KEY=your-api-key-here

# The default model to guide the browser agent.
# Supported: gemini-3.5-flash, gemini-3.5-pro, gpt-4o-mini, gpt-4o, claude-3-5-sonnet, etc.
DEFAULT_LLM_MODEL=gemini-3.5-flash

# Optional HTTP-Referer header (frequently used by OpenRouter)
# LLM_REFERER=https://github.com/spelech/playwright-csharp-scraper

# --- Browser Settings ---
# Leave empty to launch a local headless Chromium instance inside the container.
# Point to a remote browser context (e.g., browser-less/chrome or browser-sockpuppet) to offload browser execution.
# BROWSER_WS_ENDPOINT=ws://browser-sockpuppet-chrome:3000

# --- Search Settings ---
# Endpoint for SearXNG used by the discovery comparison api (/api/scrape/discover-compare)
# Fallback default: http://searxng:8080
# SEARXNG_BASE_URL=http://searxng:8080
